import vm.task::Task

// ── Handler ───────────────────────────────────────────────────────────────────

class Handler()
    var active:    bool
    var signal_id: i32          // signal_id this handler listens to
    var address:   i32          // bytecode entry address
    var task:      &Task        // active task slot (-1 = none)

    @inline
    fun init(sig: i32, addr: i32)
        signal_id = signal_id
        address  = addr
        task  = null
        active = true
