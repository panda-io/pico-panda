import vm.task::Task

// ── Handler ───────────────────────────────────────────────────────────────────

class Handler()
    var active:    bool
    var signal_id: int          // signal_id this handler listens to
    var address:   int          // bytecode entry address
    var task:      &Task        // active task slot (-1 = none)

    @inline
    fun init(sig: int, addr: int)
        signal_id = sig
        address  = addr
        task  = null
        active = true
