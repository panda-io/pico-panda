import vm.config::REGISTER_SIZE

// ── System signal IDs (shared between assembler and host) ─────────────────────
const SIGNAL_SYS_START: int = 1
const SIGNAL_APP_START: int = 2
const SIGNAL_TICK:      int = 3
const SIGNAL_EXIT:      int = 99

class Signal()
    var id:   int
    var regs: int[REGISTER_SIZE]