import test::assert
import assembler::Assembler
import vm::vm_reset
import vm::vm_load_sys
import vm::vm_boot_sys
import vm::vm_tick
import vm::vm

// ── Shared assembler instance ─────────────────────────────────────────────────

var _asm: Assembler

// ── Helpers ───────────────────────────────────────────────────────────────────

fun _build(src: u8[]) bool
    _asm.init()
    if !_asm.pass1_str(src)
        return false
    _asm.reset_pc()
    return _asm.pass2_str(src)

fun _boot_sys(src: u8[]) bool
    if !_build(src)
        return false
    vm_reset()
    vm_load_sys(_asm.get_bytecode())
    vm_boot_sys()
    return true

// ── Basic push and output ─────────────────────────────────────────────────────

@test
fun test_asm_push()
    assert(_boot_sys("""
PUSH 42
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""))
    assert(vm.output == 42)

@test
fun test_asm_push_hex()
    assert(_boot_sys("""
PUSH 0xFF
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""))
    assert(vm.output == 255)

@test
fun test_asm_push_negative()
    assert(_boot_sys("""
PUSH -7
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""))
    assert(vm.output == -7)

// ── Integer arithmetic ────────────────────────────────────────────────────────

@test
fun test_asm_add()
    assert(_boot_sys("""
PUSH 10
PUSH 3
ADD_INT
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""))
    assert(vm.output == 13)

@test
fun test_asm_sub()
    assert(_boot_sys("""
PUSH 10
PUSH 3
SUB_INT
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""))
    assert(vm.output == 7)

@test
fun test_asm_mul()
    assert(_boot_sys("""
PUSH 6
PUSH 7
MUL_INT
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""))
    assert(vm.output == 42)

@test
fun test_asm_neg()
    assert(_boot_sys("""
PUSH 5
NEG_INT
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""))
    assert(vm.output == -5)

// ── Fixed-point ───────────────────────────────────────────────────────────────

@test
fun test_asm_push_float()
    // 2.0 * 3.0 = 6.0 → FIXED_TO_INT = 6
    assert(_boot_sys("""
PUSH_FLOAT 2.0
PUSH_FLOAT 3.0
MUL_FIXED
FIXED_TO_INT
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""))
    assert(vm.output == 6)

// ── Labels and jumps ──────────────────────────────────────────────────────────

@test
fun test_asm_forward_label()
    // condition is false → jump to skip → output 99
    val src: u8[] = """
PUSH 0
JMP_IF_FALSE skip
PUSH 1
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
skip:
PUSH 99
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""
    assert(_boot_sys(src))
    assert(vm.output == 99)

@test
fun test_asm_backward_label()
    // count from 0 up to 10, output 10
    val src: u8[] = """
PUSH 0
loop:
PUSH 1
ADD_INT
DUP
PUSH 10
CMP_LT_INT
JMP_IF_TRUE loop
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""
    assert(_boot_sys(src))
    assert(vm.output == 10)

// ── CALL / RET ────────────────────────────────────────────────────────────────

@test
fun test_asm_call_ret()
    // double(21) = 42
    val src: u8[] = """
PUSH 0
CALL double
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
double:
PUSH 21
PUSH 2
MUL_INT
RET
"""
    assert(_boot_sys(src))
    assert(vm.output == 42)

// ── Comment stripping ─────────────────────────────────────────────────────────

@test
fun test_asm_comment()
    val src: u8[] = """
; full-line comment
PUSH 42  ; inline comment
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""
    assert(_boot_sys(src))
    assert(vm.output == 42)

// ── Error cases ───────────────────────────────────────────────────────────────

@test
fun test_asm_error_unknown_mnemonic()
    _asm.init()
    _asm.pass1_str("PUSH 1\nBAD_MNEMONIC\n")
    _asm.reset_pc()
    val ok: bool = _asm.pass2_str("PUSH 1\nBAD_MNEMONIC\n")
    assert(!ok)
    assert(_asm.error_count() > 0)

@test
fun test_asm_error_undefined_label()
    _asm.init()
    _asm.pass1_str("PUSH 0\nJMP_IF_FALSE nowhere\n")
    _asm.reset_pc()
    val ok: bool = _asm.pass2_str("PUSH 0\nJMP_IF_FALSE nowhere\n")
    assert(!ok)
    assert(_asm.error_count() > 0)

@test
fun test_asm_error_duplicate_label()
    _asm.init()
    val ok: bool = _asm.pass1_str("main:\nPUSH 0\nmain:\nPUSH 1\n")
    assert(!ok)
    assert(_asm.error_count() > 0)

// ── Global variables ──────────────────────────────────────────────────────────

@test
fun test_asm_global_load_store()
    // .data: x: i32 at addr 0; store 99, load back, print
    val src: u8[] = """
.data
.global x: i32
.code
PUSH 99
STORE_GLOBAL x
LOAD_GLOBAL x
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""
    assert(_boot_sys(src))
    assert(vm.output == 99)

@test
fun test_asm_global_indirect()
    // push value then address, STORE_GLOBAL_IND pops addr then val
    val src: u8[] = """
.data
.global x: i32
.code
PUSH 77
PUSH_ADDR x
STORE_GLOBAL_IND
PUSH_ADDR x
LOAD_GLOBAL_IND
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""
    assert(_boot_sys(src))
    assert(vm.output == 77)

// ── Struct field access ───────────────────────────────────────────────────────

@test
fun test_asm_struct_field()
    // struct Point { x, y }; p.y = 55; load p.y
    val src: u8[] = """
.data
.struct Point
.field x
.field y
.end
.global p: Point
.code
PUSH 55
PUSH_ADDR p
PUSH_FIELD_OFFSET Point y
ADD_INT
STORE_GLOBAL_IND
PUSH_ADDR p
PUSH_FIELD_OFFSET Point y
ADD_INT
LOAD_GLOBAL_IND
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""
    assert(_boot_sys(src))
    assert(vm.output == 55)

// ── Array slice ───────────────────────────────────────────────────────────────

@test
fun test_asm_array_slice()
    // arr: i32[4]; arr[2] = 33; load arr[2]
    val src: u8[] = """
.data
.global arr: i32[4]
.code
PUSH 33
PUSH_ADDR arr
PUSH 2
PUSH 4
MUL_INT
ADD_INT
STORE_GLOBAL_IND
PUSH_ADDR arr
PUSH 2
PUSH 4
MUL_INT
ADD_INT
LOAD_GLOBAL_IND
CALL_MODULE 0x01 0x01
CALL_MODULE 0x02 0x02
"""
    assert(_boot_sys(src))
    assert(vm.output == 33)
