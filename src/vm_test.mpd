import test::assert
import event::EVENT_SYS_START
import vm::vm_reset
import vm::vm_load_sys
import vm::vm_boot_sys
import vm::vm_send
import vm::vm_tick
import vm::vm
import opcode::*

// ── Bytecode builder helpers ──────────────────────────────────────────────────

// Write one byte, return next index
fun _wb(buf: u8[], i: i32, v: u8) i32
    buf[i] = v
    return i + 1

// Write i32 little-endian, return next index
fun _wi32(buf: u8[], i: i32, v: i32) i32
    buf[i]     = u8(v & 0xFF)
    buf[i + 1] = u8((v >> 8)  & 0xFF)
    buf[i + 2] = u8((v >> 16) & 0xFF)
    buf[i + 3] = u8((v >> 24) & 0xFF)
    return i + 4

// Write u16 little-endian, return next index
fun _wu16(buf: u8[], i: i32, v: i32) i32
    buf[i]     = u8(v & 0xFF)
    buf[i + 1] = u8((v >> 8) & 0xFF)
    return i + 2

fun _boot(code: u8[])
    vm_reset()
    vm_load_sys(code)
    vm_boot_sys()

// Emit CALL_MODULE CONSOLE PRINT_INT (3 bytes)
fun _print_int(buf: u8[], i: i32) i32
    i = _wb(buf, i, u8(OpCode.CallModule))
    i = _wb(buf, i, MODULE_CONSOLE)
    i = _wb(buf, i, u8(ConsoleCode.PrintInt))
    return i

// Emit CALL_MODULE EVENT EXIT_HANDLER (3 bytes)
fun _exit_handler(buf: u8[], i: i32) i32
    i = _wb(buf, i, u8(OpCode.CallModule))
    i = _wb(buf, i, MODULE_EVENT)
    i = _wb(buf, i, u8(EventCode.ExitHandler))
    return i

// ── PUSH ─────────────────────────────────────────────────────────────────────

@test
fun test_push()
    var raw: u8[16]
    val code: u8[] = {&raw[0], u32(16)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 42)
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 42)

// ── Integer arithmetic ────────────────────────────────────────────────────────

@test
fun test_add_int()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 10)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 3)
    i = _wb(code, i, u8(OpCode.AddInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 13)

@test
fun test_sub_int()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 10)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 3)
    i = _wb(code, i, u8(OpCode.SubInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 7)

@test
fun test_mul_int()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 6)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 7)
    i = _wb(code, i, u8(OpCode.MulInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 42)

@test
fun test_neg_int()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 5)
    i = _wb(code, i, u8(OpCode.NegInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == -5)

// ── Stack ops ─────────────────────────────────────────────────────────────────

@test
fun test_dup()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 7)
    i = _wb(code, i, u8(OpCode.Dup))
    i = _wb(code, i, u8(OpCode.AddInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 14)

@test
fun test_swap()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 10)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 3)
    i = _wb(code, i, u8(OpCode.Swap))
    i = _wb(code, i, u8(OpCode.SubInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == -7)

// ── Bitwise ───────────────────────────────────────────────────────────────────

@test
fun test_bitwise()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 0xFF)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 0x0F)
    i = _wb(code, i, u8(OpCode.And))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 0x0F)

@test
fun test_shift()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 1)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 4)
    i = _wb(code, i, u8(OpCode.ShlInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 16)

// ── Comparison + branch ───────────────────────────────────────────────────────

@test
fun test_cmp_eq()
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 5)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 5)
    i = _wb(code, i, u8(OpCode.CmpEqInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 1)

@test
fun test_jmp_if_false()
    // if 0 is false: jump to addr that pushes 99, not 1
    // layout:
    //   0: PUSH 0          (5 bytes)
    //   5: JMP_IF_FALSE 19 (3 bytes)
    //   8: PUSH 1          (5 bytes)
    //  13: PRINT_INT       (3 bytes)
    //  16: EXIT            (3 bytes)
    //  19: PUSH 99         (5 bytes)
    //  24: PRINT_INT       (3 bytes)
    //  27: EXIT            (3 bytes)
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 0)
    i = _wb(code, i, u8(OpCode.JmpIfFalse))
    i = _wu16(code, i, 19)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 1)
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 99)
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 99)

// ── CALL / RET ────────────────────────────────────────────────────────────────

@test
fun test_call_ret()
    // layout:
    //   0: PUSH 0 (argc=0)  5 bytes
    //   5: CALL 17          3 bytes
    //   8: PRINT_INT        3 bytes
    //  11: EXIT             3 bytes
    //  17: PUSH 42          5 bytes
    //  22: RET              1 byte
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 0)
    i = _wb(code, i, u8(OpCode.Call))
    i = _wu16(code, i, 17)
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    while i < 17
        i = _wb(code, i, u8(OpCode.Drop))
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 42)
    i = _wb(code, i, u8(OpCode.Ret))
    _boot({&raw[0], u32(i)})
    assert(vm.output == 42)

// ── Signal / event system ─────────────────────────────────────────────────────

@test
fun test_signal_handler()
    // Boot code (addr 0):
    //   0: PUSH EVENT_SYS_START  5 bytes
    //   5: PUSH 19               5 bytes
    //  10: EVENT CREATE_HANDLER  3 bytes
    //  13: EVENT EXIT_HANDLER    3 bytes
    // Handler (addr 19):
    //  19: PUSH 77               5 bytes
    //  24: PRINT_INT             3 bytes
    //  27: EVENT EXIT_HANDLER    3 bytes
    // Binary layout: [boot code][handler at offset 19]
    var raw: u8[64]
    val code: u8[] = {&raw[0], u32(64)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, EVENT_SYS_START)
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 19)       // handler at code-section offset 19
    i = _wb(code, i, u8(OpCode.CallModule))
    i = _wb(code, i, MODULE_EVENT)
    i = _wb(code, i, u8(EventCode.CreateHandler))
    i = _exit_handler(code, i)
    while i < 19                 // pad to offset 19
        i = _wb(code, i, u8(OpCode.Drop))
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 77)
    i = _print_int(code, i)
    i = _exit_handler(code, i)

    vm_reset()
    vm_load_sys({&raw[0], u32(i)})
    vm_boot_sys()
    vm_tick(1.0)
    assert(vm.output == 77)

// ── Fixed-point arithmetic ────────────────────────────────────────────────────

@test
fun test_int_to_fixed()
    // INT_TO_FIXED(3) = 3 << 16 = 196608
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 3)
    i = _wb(code, i, u8(OpCode.IntToFixed))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 196608)

@test
fun test_fixed_to_int()
    // FIXED_TO_INT(196608) = 196608 >> 16 = 3
    var raw: u8[32]
    val code: u8[] = {&raw[0], u32(32)}
    var i: i32 = 0
    i = _wb(code, i, u8(OpCode.Push))
    i = _wi32(code, i, 196608)
    i = _wb(code, i, u8(OpCode.FixedToInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], u32(i)})
    assert(vm.output == 3)
