import task::Task

// ── Handler ───────────────────────────────────────────────────────────────────

class Handler()
    var active:    bool
    var signal_id: i32          // signal_id this handler listens to
    var addr:      i32          // bytecode entry address
    var task:      &Task        // active task slot (-1 = none)

    @inline
    fun init(ev: i32, a: i32)
        signal_id = ev
        addr  = a
        task  = null
        active = true
