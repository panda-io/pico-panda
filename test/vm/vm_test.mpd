import test::assert
import vm.signal::SIGNAL_SYS_START
import vm.vm::vm_reset
import vm.vm::vm_load_sys
import vm.vm::vm_boot_sys
import vm.vm::vm_send
import vm.vm::vm_tick
import console
import string::equals
import vm.opcode::*

// ── Output capture ────────────────────────────────────────────────────────────

var _out_buf: byte[256]
var _out_len: int = 0

fun _cap(b: byte)
    if _out_len < 256
        _out_buf[_out_len] = b
        _out_len++

fun _out() byte[]
    return {&_out_buf[0], _out_len}

@include("stdio.h")

@extern("putchar({b})")
fun _putchar(b: byte)

fun _stdout_write(b: byte)
    _putchar(b)

// ── Bytecode builder helpers ──────────────────────────────────────────────────

// Write one byte, return next index
fun _wb(buf: byte[], i: int, v: byte) int
    buf[i] = v
    return i + 1

// Write int little-endian, return next index
fun _wi32(buf: byte[], i: int, v: int) int
    buf[i]     = byte(v & 0xFF)
    buf[i + 1] = byte((v >> 8)  & 0xFF)
    buf[i + 2] = byte((v >> 16) & 0xFF)
    buf[i + 3] = byte((v >> 24) & 0xFF)
    return i + 4

// Write u16 little-endian, return next index
fun _wu16(buf: byte[], i: int, v: int) int
    buf[i]     = byte(v & 0xFF)
    buf[i + 1] = byte((v >> 8) & 0xFF)
    return i + 2

fun _boot(code: byte[])
    _out_len = 0
    console.init(_cap)
    vm_reset()
    vm_load_sys(code)
    vm_boot_sys()
    console.init(_stdout_write)

// Emit CALL_MODULE CONSOLE PRINT_INT (3 bytes)
fun _print_int(buf: byte[], i: int) int
    i = _wb(buf, i, byte(OpCode.CallModule))
    i = _wb(buf, i, MODULE_CONSOLE)
    i = _wb(buf, i, byte(ConsoleCode.PrintInt))
    return i

// Emit CALL_MODULE SIGNAL EXIT_HANDLER (3 bytes)
fun _exit_handler(buf: byte[], i: int) int
    i = _wb(buf, i, byte(OpCode.CallModule))
    i = _wb(buf, i, MODULE_SIGNAL)
    i = _wb(buf, i, byte(SignalCode.ExitHandler))
    return i

// ── PUSH ─────────────────────────────────────────────────────────────────────

@test
fun test_push()
    var raw: byte[16]
    val code: byte[] = {&raw[0], 16}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 42)
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "42"))

// ── Integer arithmetic ────────────────────────────────────────────────────────

@test
fun test_add_int()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 10)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 3)
    i = _wb(code, i, byte(OpCode.AddInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "13"))

@test
fun test_sub_int()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 10)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 3)
    i = _wb(code, i, byte(OpCode.SubInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "7"))

@test
fun test_mul_int()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 6)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 7)
    i = _wb(code, i, byte(OpCode.MulInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "42"))

@test
fun test_neg_int()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 5)
    i = _wb(code, i, byte(OpCode.NegInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "-5"))

// ── Stack ops ─────────────────────────────────────────────────────────────────

@test
fun test_dup()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 7)
    i = _wb(code, i, byte(OpCode.Dup))
    i = _wb(code, i, byte(OpCode.AddInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "14"))

@test
fun test_swap()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 10)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 3)
    i = _wb(code, i, byte(OpCode.Swap))
    i = _wb(code, i, byte(OpCode.SubInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "-7"))

// ── Bitwise ───────────────────────────────────────────────────────────────────

@test
fun test_bitwise()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 0xFF)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 0x0F)
    i = _wb(code, i, byte(OpCode.And))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "15"))

@test
fun test_shift()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 1)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 4)
    i = _wb(code, i, byte(OpCode.ShlInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "16"))

// ── Comparison + branch ───────────────────────────────────────────────────────

@test
fun test_cmp_eq()
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 5)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 5)
    i = _wb(code, i, byte(OpCode.CmpEqInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "1"))

@test
fun test_jmp_if_false()
    // if 0 is false: jump to addr that pushes 99, not 1
    // layout:
    //   0: PUSH 0          (5 bytes)
    //   5: JMP_IF_FALSE 19 (3 bytes)
    //   8: PUSH 1          (5 bytes)
    //  13: PRINT_INT       (3 bytes)
    //  16: EXIT            (3 bytes)
    //  19: PUSH 99         (5 bytes)
    //  24: PRINT_INT       (3 bytes)
    //  27: EXIT            (3 bytes)
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 0)
    i = _wb(code, i, byte(OpCode.JmpIfFalse))
    i = _wu16(code, i, 19)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 1)
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 99)
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "99"))

// ── CALL / RET ────────────────────────────────────────────────────────────────

@test
fun test_call_ret()
    // layout:
    //   0: PUSH 0           5 bytes
    //   5: CALL 15 argc=0   4 bytes
    //   9: PRINT_INT        3 bytes
    //  12: EXIT             3 bytes
    //  15: PUSH 42          5 bytes
    //  20: RET              1 byte
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 0)
    i = _wb(code, i, byte(OpCode.Call))
    i = _wu16(code, i, 15)
    i = _wb(code, i, byte(0))        // argc = 0
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 42)
    i = _wb(code, i, byte(OpCode.Ret))
    _boot({&raw[0], i})
    assert(equals(_out(), "42"))

// ── Signal system ─────────────────────────────────────────────────────

@test
fun test_signal_handler()
    // Boot code (addr 0):
    //   0: PUSH SIGNAL_SYS_START  5 bytes
    //   5: PUSH 19               5 bytes
    //  10: SIGNAL CREATE_HANDLER  3 bytes
    //  13: SIGNAL EXIT_HANDLER    3 bytes
    // Handler (addr 19):
    //  19: PUSH 77                5 bytes
    //  24: PRINT_INT              3 bytes
    //  27: SIGNAL EXIT_HANDLER    3 bytes
    // Binary layout: [boot code][handler at offset 19]
    var raw: byte[64]
    val code: byte[] = {&raw[0], 64}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, SIGNAL_SYS_START)
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 19)       // handler at code-section offset 19
    i = _wb(code, i, byte(OpCode.CallModule))
    i = _wb(code, i, MODULE_SIGNAL)
    i = _wb(code, i, byte(SignalCode.CreateHandler))
    i = _exit_handler(code, i)
    while i < 19                 // pad to offset 19
        i = _wb(code, i, byte(OpCode.Drop))
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 77)
    i = _print_int(code, i)
    i = _exit_handler(code, i)

    _out_len = 0
    console.init(_cap)
    vm_reset()
    vm_load_sys({&raw[0], i})
    vm_boot_sys()
    vm_tick(65536)   // 1.0 ms as raw 16.16 fixed
    console.init(_stdout_write)
    assert(equals(_out(), "77"))

// ── Fixed-point arithmetic ────────────────────────────────────────────────────

@test
fun test_int_to_fixed()
    // INT_TO_FIXED(3) = 3 << 16 = 196608
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 3)
    i = _wb(code, i, byte(OpCode.IntToFixed))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "196608"))

@test
fun test_fixed_to_int()
    // FIXED_TO_INT(196608) = 196608 >> 16 = 3
    var raw: byte[32]
    val code: byte[] = {&raw[0], 32}
    var i: int = 0
    i = _wb(code, i, byte(OpCode.Push))
    i = _wi32(code, i, 196608)
    i = _wb(code, i, byte(OpCode.FixedToInt))
    i = _print_int(code, i)
    i = _exit_handler(code, i)
    _boot({&raw[0], i})
    assert(equals(_out(), "3"))
