// Return the byte offset of needle in haystack, or -1 if not found.
fun _find_str(hay: u8[], needle: u8[]) i32
    val hlen: u32 = hay.size()
    val nlen: u32 = needle.size()
    if nlen == u32(0) || nlen > hlen
        return -1
    var i: u32 = u32(0)
    while i <= hlen - nlen
        if starts_with(sub(hay, i, hlen - i), needle)
            return i32(i)
        i++
    return -1

@test
fun test_compile_priority_ordering()
    var c: Compiler
    val src: u8[] = """
@tick(1, 10)
fun high()
    asm("CALL_MODULE SIGNAL EXIT_HANDLER")
@tick(1, 1)
fun low()
    asm("CALL_MODULE SIGNAL EXIT_HANDLER")
"""
    assert(c.compile(src))
    val out: u8[] = c.asm_output()
    val pos_high: i32 = _find_str(out, "__wrap_high")
    val pos_low:  i32 = _find_str(out, "__wrap_low")
    assert(pos_high >= 0)
    assert(pos_low >= 0)
    assert(pos_high < pos_low)

@test
fun test_compile_priority_equal_stable()
    var c: Compiler
    val src: u8[] = """
@tick(1)
fun first()
    asm("CALL_MODULE SIGNAL EXIT_HANDLER")
@tick(1)
fun second()
    asm("CALL_MODULE SIGNAL EXIT_HANDLER")
"""
    assert(c.compile(src))
    val out: u8[] = c.asm_output()
    val pos_first:  i32 = _find_str(out, "__wrap_first")
    val pos_second: i32 = _find_str(out, "__wrap_second")
    assert(pos_first >= 0 && pos_second >= 0)
    assert(pos_first < pos_second)

@test
fun test_negative_priority_stored()
    var c: Compiler
    val src: u8[] = """
@tick(1, -5)
fun neg5()
    asm("CALL_MODULE SIGNAL EXIT_HANDLER")
"""
    assert(c.compile(src))
    val decls: &DeclList = c.parser().decls()
    var found_pri: i32 = 9999
    var i: i32 = 0
    while i < decls.count()
        if decls.ann_kind(i) > 0
            found_pri = decls.ann_priority(i)
        i++
    assert(found_pri == -5)

@test
fun test_compile_negative_priority_ordering()
    var c: Compiler
    val src: u8[] = """
@tick(1, -1)
fun neg1()
    asm("CALL_MODULE SIGNAL EXIT_HANDLER")
@tick(1)
fun zero()
    asm("CALL_MODULE SIGNAL EXIT_HANDLER")
"""
    assert(c.compile(src))
    val out: u8[] = c.asm_output()
    val pos_zero: i32 = _find_str(out, "__wrap_zero")
    val pos_neg1: i32 = _find_str(out, "__wrap_neg1")
    assert(pos_zero >= 0 && pos_neg1 >= 0)
    // zero (priority 0) should appear before neg1 (priority -1)
    assert(pos_zero < pos_neg1)

// ── End-to-end tests ──────────────────────────────────────────────────────────

@test
fun test_e2e_add()
    // Compile add(a, b) int; prepend a main wrapper; assemble; run via VM.
    var c: Compiler
    assert(c.compile("""
fun add(a: int, b: int) int
    return a + b
"""))
    val fn_asm: u8[] = c.asm_output()

    // main: push 3, push 4, call add, print result, exit
    val header: u8[] = """
.code
fun main:
    PUSH 3
    PUSH 4
    CALL add
    CALL_MODULE CONSOLE PRINT_INT
    CALL_MODULE SIGNAL EXIT_HANDLER
    RET
"""

    // concatenate header + fn_asm into a fixed buffer
    var combined: u8[2048]
    var pos: i32 = 0
    var i: i32 = 0
    val hlen: i32 = i32(header.size())
    while i < hlen
        combined[pos] = header[i]
        pos++
        i++
    i = 0
    val flen: i32 = i32(fn_asm.size())
    while i < flen
        combined[pos] = fn_asm[i]
        pos++
        i++

    // assemble
    var asmblr: Assembler
    asmblr.init()
    val src: u8[] = {&combined[0], u32(pos)}
    assert(asmblr.pass1_str(src))
    asmblr.reset_pc()
    assert(asmblr.pass2_str(src))
    val bc: u8[] = asmblr.get_bytecode()

    // run via VM, capture output
    _out_len = 0
    console.init(_cap)
    vm_reset()
    vm_load_sys(bc)
    vm_boot_sys()
    console.init(_stdout_write)
    assert(equals(_out(), "7"))

@test
fun test_compile_data_type()
    assert(pp_compile("""
data Vec2
    x: int
    y: fixed
var g: Vec2
"""))

@test
fun test_e2e_data_field()
    // Compile: global struct, set field, print via asm, exit via wrapper EXIT_HANDLER.
    var c: Compiler
    val src: u8[] = """
fun print_int(v: int)
    asm("LOAD_LOCAL v")
    asm("CALL_MODULE CONSOLE PRINT_INT")
data Vec2
    x: int
    y: fixed
var g_v: Vec2
@signal(1)
fun on_start()
    g_v.x = 42
    print_int(g_v.x)
"""
    assert(c.compile(src))
    val asm_text: u8[] = c.asm_output()

    var asmblr: Assembler
    asmblr.init()
    assert(asmblr.pass1_str(asm_text))
    asmblr.reset_pc()
    assert(asmblr.pass2_str(asm_text))
    val bc: u8[] = asmblr.get_bytecode()

    _out_len = 0
    console.init(_cap)
    vm_reset()
    vm_load_sys(bc)
    vm_boot_sys()
    vm_tick(1)   // dispatch queued signals (signal 1 fires on_start)
    console.init(_stdout_write)
    assert(equals(_out(), "42"))

@test
fun test_drop_on_unused_call()
    // Calling a value-returning function as a statement must emit DROP to keep stack balanced.
    var c: Compiler
    val src: u8[] = """
fun returns_int() int
    asm("PUSH 42")
@tick(1)
fun on_tick()
    returns_int()
"""
    assert(c.compile(src))
    assert(_find_str(c.asm_output(), "DROP") >= 0)
#end
