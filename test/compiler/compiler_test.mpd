// ── Output capture ────────────────────────────────────────────────────────────

var _out_buf: u8[256]
var _out_len: i32 = 0

fun _cap(b: u8)
    if _out_len < 256
        _out_buf[_out_len] = b
        _out_len++

fun _out() u8[]
    return {&_out_buf[0], u32(_out_len)}

@include("stdio.h")

@extern("putchar({b})")
fun _putchar(b: u8)

fun _stdout_write(b: u8)
    _putchar(b)

// ── Scanner tests ─────────────────────────────────────────────────────────────

@test
fun test_scan_empty()
    var heap: HeapAllocator
    var sc: Scanner
    sc.init(&heap, "")
    assert(sc.scan())
    assert(sc.token_count() == 1)   // only EOF

@test
fun test_scan_var_decl()
    var heap: HeapAllocator
    var sc: Scanner
    sc.init(&heap, "var x: int\n")
    assert(sc.scan())
    assert(sc.error_count() == 0)

@test
fun test_scan_fun_decl()
    var heap: HeapAllocator
    var sc: Scanner
    sc.init(&heap, """
fun add(a: int, b: int) int
    return a + b
""")
    assert(sc.scan())
    assert(sc.error_count() == 0)

@test
fun test_scan_string_intern()
    var heap: HeapAllocator
    var sc: Scanner
    sc.init(&heap, "var abc: int\nvar abc: int\n")
    assert(sc.scan())
    // IDENT "abc" appears twice — should get the same string index
    val si1: i32 = sc.tok_val(1)   // tokens: VAR IDENT COLON INT NEWLINE ...
    val si2: i32 = sc.tok_val(6)   // second VAR IDENT...
    assert(si1 == si2)

// ── Parser tests ──────────────────────────────────────────────────────────────

@test
fun test_parse_empty()
    var heap: HeapAllocator
    var sc: Scanner
    sc.init(&heap, "")
    sc.scan()
    var p: Parser
    p.init(&heap, &sc)
    assert(p.parse())
    assert(p.decls().count() == 0)

@test
fun test_parse_global_var()
    var heap: HeapAllocator
    var sc: Scanner
    sc.init(&heap, "var x: int\n")
    sc.scan()
    var p: Parser
    p.init(&heap, &sc)
    assert(p.parse())
    assert(p.decls().count() == 1)

@test
fun test_parse_fun()
    var heap: HeapAllocator
    var sc: Scanner
    sc.init(&heap, """
fun add(a: int, b: int) int
    return a + b
""")
    sc.scan()
    var p: Parser
    p.init(&heap, &sc)
    assert(p.parse())
    assert(p.decls().count() == 1)
    assert(p.decls().kind(0) == i32(DeclKind.FUN))

