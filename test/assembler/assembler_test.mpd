import test::assert
import assembler.assembler::Assembler
import vm.vm::vm_reset
import vm.vm::vm_load_sys
import vm.vm::vm_boot_sys
import vm.vm::vm_tick
import console
import string::equals

// ── Output capture ────────────────────────────────────────────────────────────

var _out_buf: byte[256]
var _out_len: int = 0

fun _cap(b: byte)
    if _out_len < 256
        _out_buf[_out_len] = b
        _out_len++

fun _out() byte[]
    return {&_out_buf[0], _out_len}

@include("stdio.h")

@extern("putchar({b})")
fun _putchar(b: byte)

fun _stdout_write(b: byte)
    _putchar(b)

// ── Shared assembler instance ─────────────────────────────────────────────────

var _asm: Assembler

// ── Helpers ───────────────────────────────────────────────────────────────────

fun _build(src: byte[]) bool
    _asm.init()
    if !_asm.pass1_str(src)
        return false
    _asm.reset_pc()
    return _asm.pass2_str(src)

fun _boot_sys(src: byte[]) bool
    _out_len = 0
    console.init(_cap)
    if !_build(src)
        return false
    vm_reset()
    vm_load_sys(_asm.get_bytecode())
    vm_boot_sys()
    console.init(_stdout_write)
    return true

// ── Basic push and output ─────────────────────────────────────────────────────

@test
fun test_asm_push()
    assert(_boot_sys("""
PUSH 42
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "42"))

@test
fun test_asm_push_hex()
    assert(_boot_sys("""
PUSH 0xFF
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "255"))

@test
fun test_asm_push_negative()
    assert(_boot_sys("""
PUSH -7
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "-7"))

// ── Integer arithmetic ────────────────────────────────────────────────────────

@test
fun test_asm_add()
    assert(_boot_sys("""
PUSH 10
PUSH 3
ADD_INT
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "13"))

@test
fun test_asm_sub()
    assert(_boot_sys("""
PUSH 10
PUSH 3
SUB_INT
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "7"))

@test
fun test_asm_mul()
    assert(_boot_sys("""
PUSH 6
PUSH 7
MUL_INT
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "42"))

@test
fun test_asm_neg()
    assert(_boot_sys("""
PUSH 5
NEG_INT
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "-5"))

// ── Fixed-point ───────────────────────────────────────────────────────────────

@test
fun test_asm_push_float()
    // 2.0 * 3.0 = 6.0 → FIXED_TO_INT = 6
    assert(_boot_sys("""
PUSH_FLOAT 2.0
PUSH_FLOAT 3.0
MUL_FIXED
FIXED_TO_INT
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "6"))

// ── Labels and jumps ──────────────────────────────────────────────────────────

@test
fun test_asm_forward_label()
    // condition is false → jump to skip → output 99
    val src: byte[] = """
PUSH 0
JMP_IF_FALSE skip
PUSH 1
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
skip:
PUSH 99
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""
    assert(_boot_sys(src))
    assert(equals(_out(), "99"))

@test
fun test_asm_backward_label()
    // count from 0 up to 10, output 10
    val src: byte[] = """
PUSH 0
loop:
PUSH 1
ADD_INT
DUP
PUSH 10
CMP_LT_INT
JMP_IF_TRUE loop
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""
    assert(_boot_sys(src))
    assert(equals(_out(), "10"))

// ── CALL / RET ────────────────────────────────────────────────────────────────

@test
fun test_asm_call_ret()
    // double(21) = 42
    val src: byte[] = """
PUSH 0
CALL double
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
double:
PUSH 21
PUSH 2
MUL_INT
RET
"""
    assert(_boot_sys(src))
    assert(equals(_out(), "42"))

// ── Comment stripping ─────────────────────────────────────────────────────────

@test
fun test_asm_comment()
    val src: byte[] = """
; full-line comment
PUSH 42  ; inline comment
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""
    assert(_boot_sys(src))
    assert(equals(_out(), "42"))

// ── Error cases ───────────────────────────────────────────────────────────────

@test
fun test_asm_error_unknown_mnemonic()
    _asm.init()
    _asm.pass1_str("PUSH 1\nBAD_MNEMONIC\n")
    _asm.reset_pc()
    val ok: bool = _asm.pass2_str("PUSH 1\nBAD_MNEMONIC\n")
    assert(!ok)
    assert(_asm.error_count() > 0)

@test
fun test_asm_error_undefined_label()
    _asm.init()
    _asm.pass1_str("PUSH 0\nJMP_IF_FALSE nowhere\n")
    _asm.reset_pc()
    val ok: bool = _asm.pass2_str("PUSH 0\nJMP_IF_FALSE nowhere\n")
    assert(!ok)
    assert(_asm.error_count() > 0)

@test
fun test_asm_error_duplicate_label()
    _asm.init()
    val ok: bool = _asm.pass1_str("main:\nPUSH 0\nmain:\nPUSH 1\n")
    assert(!ok)
    assert(_asm.error_count() > 0)

// ── Global variables ──────────────────────────────────────────────────────────

@test
fun test_asm_global_load_store()
    // .data: x: int at addr 0; store 99, load back, print
    val src: byte[] = """
.data
.global x: int
.code
PUSH 99
STORE_GLOBAL x
LOAD_GLOBAL x
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""
    assert(_boot_sys(src))
    assert(equals(_out(), "99"))

@test
fun test_asm_global_indirect()
    // push value then address, STORE_GLOBAL_IND pops addr then val
    val src: byte[] = """
.data
.global x: int
.code
PUSH 77
PUSH_ADDR x
STORE_GLOBAL_IND
PUSH_ADDR x
LOAD_GLOBAL_IND
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""
    assert(_boot_sys(src))
    assert(equals(_out(), "77"))

// ── Struct field access ───────────────────────────────────────────────────────

@test
fun test_asm_struct_field()
    // struct Point { x, y }; p.y = 55; load p.y
    val src: byte[] = """
.data
.struct Point
.field x
.field y
.end
.global p: Point
.code
PUSH 55
PUSH_ADDR p
PUSH_FIELD_OFFSET Point y
ADD_INT
STORE_GLOBAL_IND
PUSH_ADDR p
PUSH_FIELD_OFFSET Point y
ADD_INT
LOAD_GLOBAL_IND
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""
    assert(_boot_sys(src))
    assert(equals(_out(), "55"))

// ── fun / .local / LOAD_LOCAL / STORE_LOCAL ───────────────────────────────────

@test
fun test_asm_fun_args()
    // add(10, 20) = 30
    assert(_boot_sys("""
PUSH 10
PUSH 20
CALL add
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
fun add:
    .local a
    .local b
    LOAD_LOCAL a
    LOAD_LOCAL b
    ADD_INT
    RET
"""))
    assert(equals(_out(), "30"))

@test
fun test_asm_store_local()
    // dbl(7) = 14 (doubles arg via STORE_LOCAL)
    assert(_boot_sys("""
PUSH 7
CALL dbl
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
fun dbl:
    .local x
    LOAD_LOCAL x
    PUSH 2
    MUL_INT
    STORE_LOCAL x
    LOAD_LOCAL x
    RET
"""))
    assert(equals(_out(), "14"))

@test
fun test_asm_callee_var()
    // abs(-7): callee stores result in a .var slot
    assert(_boot_sys("""
PUSH -7
CALL abs_fn
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
fun abs_fn:
    .local x
    .var   result
    LOAD_LOCAL x
    PUSH 0
    CMP_LT_INT
    JMP_IF_FALSE abs_pos
    PUSH 0
    LOAD_LOCAL x
    SUB_INT
    STORE_LOCAL result
    JMP abs_done
abs_pos:
    LOAD_LOCAL x
    STORE_LOCAL result
abs_done:
    LOAD_LOCAL result
    RET
"""))
    assert(equals(_out(), "7"))

// ── Array slice ───────────────────────────────────────────────────────────────

@test
fun test_asm_array_slice()
    // arr: int[4]; arr[2] = 33; load arr[2]
    val src: byte[] = """
.data
.global arr: int[4]
.code
PUSH 33
PUSH_ADDR arr
PUSH 2
PUSH 4
MUL_INT
ADD_INT
STORE_GLOBAL_IND
PUSH_ADDR arr
PUSH 2
PUSH 4
MUL_INT
ADD_INT
LOAD_GLOBAL_IND
CALL_MODULE CONSOLE PRINT_INT
CALL_MODULE SIGNAL EXIT_HANDLER
"""
    assert(_boot_sys(src))
    assert(equals(_out(), "33"))

// ── PUSH_STR / PRINT_STR ──────────────────────────────────────────────────────

@test
fun test_asm_push_str()
    assert(_boot_sys("""
PUSH_STR "hello"
CALL_MODULE CONSOLE PRINT_STR
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "hello"))

@test
fun test_asm_push_str_spaces()
    // string with spaces and a comment that should NOT be stripped
    assert(_boot_sys("""
PUSH_STR "foo bar"
CALL_MODULE CONSOLE PRINT_STR
CALL_MODULE SIGNAL EXIT_HANDLER
"""))
    assert(equals(_out(), "foo bar"))
